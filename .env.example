# --- Account A: Azure OpenAI (Person 1) ---
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=o4-mini

# --- Account A: Azure Maps (Person 1) ---
AZURE_MAPS_KEY=your_maps_key

# --- Account B: Cosmos DB + Event Hub + Bot (Person 2) ---
COSMOS_DB_ENDPOINT=https://fraudshield-graphdb.documents.azure.com:443/
COSMOS_DB_KEY=your_cosmos_key
EVENT_HUB_CONNECTION=your_eventhub_connection_string
BOT_APP_ID=your_bot_app_id
BOT_APP_PASSWORD=your_bot_password

# --- Account C: Functions + Language (Person 3) ---
FUNCTION_APP_URL=https://fraudshield-api.azurewebsites.net/api/classify
FUNCTION_KEY=your_function_key_from_portal
LANGUAGE_ENDPOINT=https://your-language.cognitiveservices.azure.com/
LANGUAGE_KEY=your_language_key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
FRAUDSHIELD_API_URL=https://fraudshield-api.azurewebsites.net/api/classify
