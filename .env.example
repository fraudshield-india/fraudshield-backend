
# Azure OpenAI (o4-mini on Azure AI Foundry)
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-endpoint.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key_here

# Account B: Cosmos DB + Event Hub + Bot (Person 2)
COSMOS_DB_ENDPOINT=your_cosmos_endpoint
COSMOS_DB_KEY=your_cosmos_key
EVENT_HUB_CONNECTION=your_eventhub_connection
BOT_APP_ID=your_bot_app_id
BOT_APP_PASSWORD=your_bot_password

# Account C: Functions + Language (Person 3)
FUNCTION_APP_URL=https://your-functions.azurewebsites.net/api/classify
FUNCTION_KEY=your_function_key

# Account A: Maps (Person 1)
AZURE_MAPS_KEY=your_maps_key
